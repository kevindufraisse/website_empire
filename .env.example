# Certifications alumni (POST /api/certifications — Bearer token)
CERTIFICATIONS_ADMIN_KEY=

# ─── Supabase (applications table + certifications API) ─────────────────────────
# Dashboard → Settings → API : URL, anon (public), service_role → secret server-side only
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Callback form webhook (Make/N8N/Zapier endpoint)
CALLBACK_WEBHOOK_URL=

# WAHA WhatsApp API (optional - for direct WhatsApp notifications)
WAHA_API_URL=
WAHA_SESSION=default
NOTIFY_PHONE_NUMBER=

# ─── Systeme.io (Empire Creator Quiz) ──────────────────────────────────────────
# Public API key (Profile → Settings → Public API keys)
SYSTEMEIO_API_KEY=

# Tag IDs — get them all at once with:
#   SYSTEMEIO_API_KEY=xxx node scripts/list-systeme-tags.mjs
SYSTEMEIO_TAG_QUIZ_COMPLETED=
SYSTEMEIO_TAG_QUIZ_STARTED=

SYSTEMEIO_TAG_ARCHETYPE_STORYTELLER=
SYSTEMEIO_TAG_ARCHETYPE_BUILDER=
SYSTEMEIO_TAG_ARCHETYPE_EDUCATOR=
SYSTEMEIO_TAG_ARCHETYPE_PROVOCATEUR=

SYSTEMEIO_TAG_SCORE_HIGH=
SYSTEMEIO_TAG_SCORE_MEDIUM=
SYSTEMEIO_TAG_SCORE_LOW=

SYSTEMEIO_TAG_OFFER_ACADEMY=
SYSTEMEIO_TAG_OFFER_AUTOPILOT=
SYSTEMEIO_TAG_OFFER_COPILOT=
SYSTEMEIO_TAG_OFFER_NURTURE=

# Language segmentation tags (optional — lets you filter EN vs FR audiences)
SYSTEMEIO_TAG_LANG_EN=
SYSTEMEIO_TAG_LANG_FR=

# EN-specific tags (optional — falls back to base FR tag if not set)
# Duplicate any base tag with _EN suffix to create separate EN audiences.
# Example: SYSTEMEIO_TAG_QUIZ_COMPLETED_EN=456
SYSTEMEIO_TAG_QUIZ_COMPLETED_EN=
SYSTEMEIO_TAG_QUIZ_STARTED_EN=
SYSTEMEIO_TAG_ARCHETYPE_STORYTELLER_EN=
SYSTEMEIO_TAG_ARCHETYPE_BUILDER_EN=
SYSTEMEIO_TAG_ARCHETYPE_EDUCATOR_EN=
SYSTEMEIO_TAG_ARCHETYPE_PROVOCATEUR_EN=
SYSTEMEIO_TAG_SCORE_HIGH_EN=
SYSTEMEIO_TAG_SCORE_MEDIUM_EN=
SYSTEMEIO_TAG_SCORE_LOW_EN=
SYSTEMEIO_TAG_OFFER_ACADEMY_EN=
SYSTEMEIO_TAG_OFFER_AUTOPILOT_EN=
SYSTEMEIO_TAG_OFFER_COPILOT_EN=
SYSTEMEIO_TAG_OFFER_NURTURE_EN=

# Custom field slugs (Systeme.io contact custom fields)
SYSTEMEIO_FIELD_SLUG_ARCHETYPE=
SYSTEMEIO_FIELD_SLUG_SCORE=
SYSTEMEIO_FIELD_SLUG_OFFER=
